{
  "schema_version": "1.0",
  "suite": "targeted-v2",
  "seed": 42,
  "n_bags_per_class": 32,
  "n_features": 4,
  "bag_size": 30,
  "replicates": 1,
  "n_splits": 4,
  "n_repeats": 1,
  "lambda_reg": 0.1,
  "rf_estimators": 300,
  "include_baselines": true,
  "include_mean_std_baseline": true,
  "run_invariance_checks": false,
  "methods": [
    {"id": "M0", "method": "M0"},
    {"id": "M1", "method": "M1", "rff_features": 128},
    {"id": "M1-rff512", "method": "M1", "rff_features": 512},
    {"id": "M2", "method": "M2", "rff_features": 128},
    {"id": "M3", "method": "M3", "n_projections": 64, "n_quantiles": 64}
  ],
  "scenarios": [
    {"scenario": "null", "effect_sizes": [0.0], "replicates": 8},
    {
      "scenario": "moment_matched_xor",
      "effect_sizes": [0.85, 0.95],
      "n_features": 2,
      "n_signal_features": 2,
      "bag_size": 120,
      "replicates": 6
    },
    {
      "scenario": "mean_shift",
      "effect_sizes": [0.25],
      "bag_sizes": [3, 5, 10, 30],
      "replicates": 5
    },
    {
      "scenario": "mean_shift",
      "effect_sizes": [0.25],
      "spatial_ranges": [0.0, 1.5, 5.0],
      "replicates": 5
    },
    {
      "scenario": "mean_shift",
      "effect_sizes": [0.25],
      "unequal_bag_sizes": true,
      "min_bag_size": 3,
      "max_bag_size": 30,
      "replicates": 5
    },
    {
      "scenario": "sparse_signal",
      "effect_sizes": [0.15, 0.30],
      "n_features": 30,
      "replicates": 4
    }
  ],
  "output": "benchmark_data/synthetic_lab_targeted_v2_results.json"
}

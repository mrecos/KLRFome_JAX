{
  "schema_version": "1.0",
  "suite": "representation-extensions-smoke",
  "seed": 42,
  "n_bags_per_class": 5,
  "n_features": 3,
  "bag_size": 8,
  "replicates": 1,
  "n_splits": 2,
  "n_repeats": 1,
  "inner_splits": 2,
  "reference_bag_size": 60,
  "lambda_reg": 0.1,
  "include_baselines": false,
  "run_invariance_checks": true,
  "methods": [
    {"id": "M0", "method": "M0"},
    {"id": "M1-iid", "method": "M1", "rff_features": 16},
    {
      "id": "M1-orf",
      "method": "M1",
      "rff_features": 16,
      "rff_scheme": "orthogonal"
    },
    {
      "id": "M1-orf-shrink",
      "method": "M1",
      "rff_features": 16,
      "rff_scheme": "orthogonal",
      "embedding_estimator": "shrinkage"
    },
    {"id": "M3", "method": "M3", "n_projections": 8, "n_quantiles": 8},
    {
      "id": "M4",
      "method": "M4",
      "rff_features": 16,
      "rff_scheme": "orthogonal",
      "n_projections": 8,
      "n_quantiles": 8,
      "hybrid_weights": [0.0, 0.5, 1.0]
    }
  ],
  "scenarios": [
    {"scenario": "null", "effect_sizes": [0.0]},
    {"scenario": "mean_shift", "effect_sizes": [0.3], "bag_sizes": [3, 10]},
    {
      "scenario": "moment_matched_xor",
      "effect_sizes": [0.95],
      "n_features": 2,
      "n_signal_features": 2,
      "bag_size": 40
    }
  ],
  "output": "benchmark_data/synthetic_lab_extensions_smoke_results.json"
}

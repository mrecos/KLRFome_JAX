{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KLRfome synthetic methods laboratory result",
  "type": "object",
  "required": [
    "schema_version",
    "configuration",
    "configuration_sha256",
    "environment",
    "cases"
  ],
  "properties": {
    "schema_version": {"const": "1.2"},
    "configuration": {"type": "object"},
    "configuration_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "environment": {"type": "object"},
    "rff_frequency_cache": {
      "type": "object",
      "required": ["hits", "misses", "maxsize", "currsize"],
      "properties": {
        "hits": {"type": "integer", "minimum": 0},
        "misses": {"type": "integer", "minimum": 0},
        "maxsize": {"type": "integer", "minimum": 0},
        "currsize": {"type": "integer", "minimum": 0}
      }
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "case_id",
          "scenario",
          "dataset_fingerprint",
          "fold_plan",
          "fold_results",
          "paired_differences",
          "out_of_fold_results",
          "paired_oof_differences"
        ],
        "properties": {
          "case_id": {"type": "string"},
          "scenario": {"type": "object"},
          "dataset_fingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "fold_plan": {"type": "object"},
          "fold_results": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["method", "architecture", "repeat", "fold", "embedding_mse"],
              "properties": {
                "method": {"type": "string"},
                "architecture": {"type": "string"},
                "repeat": {"type": "integer", "minimum": 1},
                "fold": {"type": "integer", "minimum": 1},
                "embedding_mse": {"type": ["number", "null"], "minimum": 0}
              }
            }
          },
          "paired_differences": {"type": "object"},
          "out_of_fold_results": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "method",
                "architecture",
                "repeat",
                "n_observations",
                "top_5_percent_selected",
                "bag_ids",
                "labels",
                "scores",
                "auc",
                "pr_auc",
                "boyce",
                "top_5_percent_lift",
                "score_separation"
              ],
              "properties": {
                "method": {"type": "string"},
                "architecture": {"type": "string"},
                "repeat": {"type": "integer", "minimum": 1},
                "n_observations": {"type": "integer", "minimum": 1},
                "top_5_percent_selected": {"type": "integer", "minimum": 1},
                "bag_ids": {"type": "array", "items": {"type": "string"}},
                "labels": {"type": "array", "items": {"type": "integer", "enum": [0, 1]}},
                "scores": {"type": "array", "items": {"type": "number"}},
                "auc": {"type": ["number", "null"]},
                "pr_auc": {"type": ["number", "null"]},
                "boyce": {"type": ["number", "null"]},
                "top_5_percent_lift": {"type": ["number", "null"]},
                "score_separation": {"type": ["number", "null"]}
              }
            }
          },
          "paired_oof_differences": {"type": "object"},
          "invariance": {"type": ["object", "null"]}
        }
      }
    }
  }
}

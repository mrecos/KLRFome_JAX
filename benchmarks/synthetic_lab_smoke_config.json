{
  "schema_version": "1.0",
  "suite": "smoke",
  "seed": 42,
  "n_bags_per_class": 6,
  "n_features": 2,
  "bag_size": 8,
  "replicates": 1,
  "n_splits": 2,
  "n_repeats": 1,
  "lambda_reg": 0.1,
  "rf_estimators": 20,
  "include_baselines": true,
  "include_mean_std_baseline": true,
  "run_invariance_checks": true,
  "methods": [
    {"id": "M0", "method": "M0"},
    {"id": "M1", "method": "M1", "rff_features": 16},
    {"id": "M2", "method": "M2", "rff_features": 16},
    {"id": "M3", "method": "M3", "n_projections": 8, "n_quantiles": 8}
  ],
  "scenarios": [
    {"scenario": "mean_shift", "effect_sizes": [0.8], "bag_sizes": [8]}
  ],
  "output": "benchmark_data/synthetic_lab_smoke_results.json"
}
